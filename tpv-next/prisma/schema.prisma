generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String

  plan      Plan     @default(FREE)
  stripeId  String?

  createdAt DateTime @default(now())

  users     User[]
  stores    Store[]
}

model Store {
  id        String   @id @default(cuid())
  name      String
  address   String?

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  tickets   Ticket[]
  users     User[]
  shifts    Shift[]
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  name      String

  role      Role

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  storeId   String?
  store     Store? @relation(fields: [storeId], references: [id])

  tickets   Ticket[]
  shifts    Shift[]
  attendances Attendance[]
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  CASHIER
  WAITER
  KITCHEN
  BAR
}

enum Plan {
  FREE
  BASIC
  PRO
  PREMIUM
}

model Category {
  id   String @id @default(cuid())
  name String

  products Product[]
}

model Product {
  id      String  @id @default(cuid())
  name    String
  price   Float
  cost    Float?
  barcode String? @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  ticketItems TicketItem[]
  recipeItems RecipeItem[]
}

model Ticket {
  id     String       @id @default(cuid())
  total  Float        @default(0)
  status TicketStatus @default(OPEN)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  items     TicketItem[]
  createdAt DateTime     @default(now())
}

enum TicketStatus {
  OPEN
  PAID
  CANCELLED
}

model TicketItem {
  id       String @id @default(cuid())
  quantity Int
  price    Float

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  kitchenItems KitchenItem[]
}

model KitchenItem {
  id String @id @default(cuid())

  status  KitchenStatus @default(PENDING)
  station Station

  ticketItemId String
  ticketItem   TicketItem @relation(fields: [ticketItemId], references: [id])

  createdAt DateTime @default(now())
}

enum KitchenStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum Station {
  KITCHEN
  BAR
}

model Ingredient {
  id    String @id @default(cuid())
  name  String
  unit  String
  stock Float  @default(0)

  recipeItems RecipeItem[]
  movements   StockMovement[]
}

model RecipeItem {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  quantity Float
}

model StockMovement {
  id String @id @default(cuid())

  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  quantity Float
  reason   String

  createdAt DateTime @default(now())
}

model Shift {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  start   DateTime
  end     DateTime?
  store   Store?    @relation(fields: [storeId], references: [id])
  storeId String?
}

model Attendance {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  checkIn  DateTime
  checkOut DateTime?
}
